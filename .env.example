# ph-economic-tracker — environment configuration
# Copy to .env and adjust. Never commit .env to version control.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Full DSN — used by the Python pipeline
PH_TRACKER_POSTGRES_DSN=postgresql://tracker:tracker@localhost:5432/ph_economic

# Individual fields — used by dbt profiles.yml and docker-compose
PH_TRACKER_PG_HOST=localhost
PH_TRACKER_PG_PORT=5432
PH_TRACKER_PG_USER=tracker
PH_TRACKER_PG_PASSWORD=tracker
PH_TRACKER_PG_DBNAME=ph_economic

# ── Pipeline ──────────────────────────────────────────────────────────────────
# Earliest year to fetch for all historical series
PH_TRACKER_START_YEAR=2000

# PSA API timeout (seconds) — PSA can be slow
PH_TRACKER_PSA_REQUEST_TIMEOUT=60

# World Bank records per page
PH_TRACKER_WORLD_BANK_PER_PAGE=100

# HTTP retry config
PH_TRACKER_MAX_RETRIES=3
PH_TRACKER_RETRY_BASE_DELAY=2.0

# ── Docker port overrides (optional) ─────────────────────────────────────────
PG_PORT=5432
STREAMLIT_PORT=8501
ADMINER_PORT=8080

# ── BSP monthly CSV (optional enrichment) ────────────────────────────────────
# If you download BSP monthly remittance data, point this at the CSV file.
# Without it, the pipeline uses World Bank annual data — fully functional.
# BSP_CSV_PATH=data/bsp_ofw_remittances.csv
